<?xml version="1.0" encoding="utf-8"?>
<!--
  Clipzy's Sparkle update feed.

  This file starts empty on purpose — Sparkle only shows an update once an
  <item> exists here with a version newer than what's installed. Each
  release, add one <item> block above the closing </channel> tag, newest
  first. See README.md "Releasing a new version" for the exact steps
  (building, signing with Sparkle's sign_update, and what goes in each
  field below).

  Example item:

  <item>
    <title>Version 2.18</title>
    <sparkle:releaseNotesLink>https://github.com/gloriandesigns/clipzy/releases/tag/v2.18.0</sparkle:releaseNotesLink>
    <pubDate>Thu, 24 Jul 2026 00:00:00 +0000</pubDate>
    <enclosure
      url="https://github.com/gloriandesigns/clipzy/releases/download/v2.18.0/Clipzy.zip"
      sparkle:version="44"
      sparkle:shortVersionString="2.18"
      length="0"
      type="application/octet-stream"
      sparkle:edSignature="PASTE_SIGNATURE_FROM_sign_update_HERE" />
  </item>
-->
<rss version="2.0" xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle">
  <channel>
    <title>Clipzy Updates</title>
    <link>https://raw.githubusercontent.com/gloriandesigns/clipzy/main/appcast.xml</link>
    <description>Update feed for Clipzy, a notch-based clipboard tray for macOS.</description>
    <language>en</language>
  </channel>
</rss>
